BOT_TOKEN=
# Comma-separated admin/developer IDs (first is primary, gets notifications).
BOT_DEV_IDS=123456789
BOT_GROUP_ID=-100123456789
BOT_EMOJI_ID=5417915203100613993

# PostgreSQL (user layer + broadcast subscribers) — asyncpg DSN
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (FSM + apscheduler job store only). PASSWORD empty when no auth.
REDIS_HOST=hm-redis
REDIS_PORT=6379
REDIS_DB=7
REDIS_PASSWORD=

# Policy engine (optional, disabled by default)
POLICY_ENABLED=false
POLICY_CONFIG_PATH=config/policy.yaml
# Fallback when the file above is not present: base64-encoded policy YAML.
# Useful on hosts where mounting a file is awkward (e.g. Coolify compose).
POLICY_YAML_B64=

# LLM layer (optional, disabled by default)
# AI_PROVIDER: none | openai_compatible
AI_PROVIDER=none
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=openai/gpt-5-nano
AI_SYSTEM_PROMPT_PATH=config/system_prompt.txt
# Fallback when the file above is not present: base64-encoded system prompt.
AI_SYSTEM_PROMPT_B64=
AI_TIMEOUT_S=8
